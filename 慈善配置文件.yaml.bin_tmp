# =====================
# 代理组
# =====================

proxy-groups:


  - name: "自动中转"

    type: url-test

    proxies:

      - "香港02 HKT"
      - "香港03 HKT"

      - "香港 aws  优化线路"
      - "新加坡 aws  优化线路"
      - "日本 aws  优化线路"

      - "新加坡1|高速下载|移动优化"
      - "新加坡2|高速下载|移动优化"
      
      - "A-WS-中转"

    url: https://www.gstatic.com/generate_204

    interval: 300

    tolerance: 50



  - name: "链式代理"

    type: select

    proxies:

      - "住宅-洛杉矶"

      - "自动中转"

      - DIRECT

  - name: "社媒住宅"

    type: select

    proxies:

      - "住宅-洛杉矶"

  - name: "Google专用"
    type: select
    proxies:
      - "香港 aws  优化线路"

  

# =====================
# 分流规则
# =====================

rules:


# 广告拦截

  - RULE-SET,reject,REJECT

  - RULE-SET,anti-ad,REJECT

# 局域网

  - IP-CIDR,127.0.0.0/8,DIRECT

  - IP-CIDR,192.168.0.0/16,DIRECT

  - IP-CIDR,10.0.0.0/8,DIRECT

  - IP-CIDR,172.16.0.0/12,DIRECT



# 国内直连

  - GEOSITE,cn,DIRECT

  - GEOIP,CN,DIRECT



